# Local Supabase Edge Functions Environment
# Copy to .env.local and fill in values from Supabase dashboard

# Supabase Connection (from Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# AI Provider (from Anthropic Console)
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# Usage:
# npx supabase functions serve agent-translate-local --env-file .env.local
