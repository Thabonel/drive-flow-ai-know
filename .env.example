# Supabase Configuration
# Set these to your actual Supabase project values:
# VITE_SUPABASE_URL="https://your-project-id.supabase.co"
# VITE_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# Environment Configuration
# Set to 'production', 'staging', or 'development'
VITE_ENVIRONMENT="development"

# AI Provider API Keys
VITE_OPENAI_API_KEY=<OPENAI_API_KEY>

# Google API Configuration - No longer needed (using OAuth-only pattern)
# VITE_GOOGLE_API_KEY - REMOVED: Now using direct API calls with OAuth tokens

# Note: Never commit the actual .env file with real credentials
# Copy this file to .env and fill in your actual values
